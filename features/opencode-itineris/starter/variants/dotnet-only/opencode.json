{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "task": {
          "frontend-developer": "deny",
          "frontend-code-reviewer": "deny",
          "ui-ux-designer": "deny"
        },
        "bash": {
          "dotnet restore*": "allow",
          "dotnet build*": "allow",
          "dotnet test*": "allow",
          "dotnet format*": "allow",
          "dotnet ef *": "ask"
        }
      }
    },
    "plan": {
      "permission": {
        "task": {
          "frontend-code-reviewer": "deny",
          "ui-ux-designer": "deny"
        }
      }
    }
  }
}