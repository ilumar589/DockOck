        "task": {
          "backend-developer": "deny",
          "frontend-developer": "deny",
          "frontend-code-reviewer": "deny",
          "ui-ux-designer": "deny",
          "product-engineer": "deny",
          "devops-engineer": "allow",
          "kubernetes-expert": "allow",
          "build-engineer": "allow",
          "sre-engineer": "allow",
          "security-engineer": "allow",
