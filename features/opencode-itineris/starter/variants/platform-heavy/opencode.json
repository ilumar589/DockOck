        "task": {
          "backend-code-reviewer": "deny",
          "frontend-code-reviewer": "deny",
          "ui-ux-designer": "deny",
          "devops-engineer": "allow",
          "kubernetes-expert": "allow",
          "sre-engineer": "allow",
